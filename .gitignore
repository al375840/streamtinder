# ============================================================
# Streamer Tinder — .gitignore
# Stack: .NET 8 + Angular 17 + Azure
# RULE: if it can contain a secret, it's ignored.
# ============================================================

# ------------------------------------------------------------
# SECRETS & CREDENTIALS — never committed, ever
# ------------------------------------------------------------
# .NET user secrets and local overrides
appsettings.Development.json
appsettings.Local.json
appsettings.Secrets.json
appsettings.Production.json
secrets.json
*.pfx
*.p12
*.key
*.pem

# Environment files (Angular, Node, general)
.env
.env.*
!.env.example

# Azure publish profiles and credentials
*.pubxml.user
*.PublishSettings
local.settings.json

